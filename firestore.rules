rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /menu_items/{itemId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /tables/{tableId} {
        allow read: if true;
        // MVP note: tighten table-scoped customer updates after anonymous sessions are added.
        allow update: if true;
        allow create, delete: if request.auth != null;
      }

      match /orders/{orderId} {
        allow read: if true;
        // MVP note: customers need limited create/update access from QR ordering.
        // Validate restaurantId/tableId and item fields before production launch.
        allow create, update: if true;
        allow delete: if request.auth != null;
      }
    }
  }
}
